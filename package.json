{
  "name": "lmix",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:migration": "npx supabase db diff -s public,extentions,storage,auth -f migration",
    "dev:types": "npx supabase gen types --lang=typescript --local --schema public > types/gravity.ts",
    "dev:update": "npx npm-check-updates -u",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.72",
    "@ai-sdk/vue": "^0.0.59",
    "@formkit/addons": "^1.6.7",
    "@formkit/auto-animate": "^0.8.2",
    "@formkit/icons": "^1.6.7",
    "@formkit/nuxt": "^1.6.7",
    "@formkit/pro": "^0.127.6",
    "@formkit/tempo": "^0.1.2",
    "@nuxt/ui": "^2.19.2",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/supabase": "^1.4.2",
    "@pinia/nuxt": "^0.7.0",
    "ai": "^3.4.33",
    "markdown-it": "^14.1.0",
    "nuxt": "^3.14.159",
    "pinia": "^2.2.6",
    "tailwind-merge": "^2.5.4",
    "vue": "latest",
    "vue-router": "latest",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@iconify-json/ph": "^1.2.1",
    "@playwright/test": "^1.40.0",
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "latest",
    "husky": "latest",
    "prettier": "latest",
    "vitest": "^1.0.0"
  },
  "overrides": {
    "vue": "latest"
  }
}
